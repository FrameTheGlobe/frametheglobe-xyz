# FrameTheGlobe — Hostinger Apache config
# Ensures Next.js static chunks are served with correct MIME types
# and all requests are proxied through the Node.js process.

Options -Indexes
AddDefaultCharset UTF-8

# ── Correct MIME types (Apache on some Hostinger plans defaults to text/plain) ─
AddType text/css                    .css
AddType application/javascript      .js
AddType application/json            .json
AddType image/svg+xml               .svg
AddType image/x-icon                .ico
AddType image/png                   .png
AddType image/jpeg                  .jpg .jpeg
AddType image/webp                  .webp
AddType font/woff2                  .woff2
AddType font/woff                   .woff
AddType application/manifest+json   .webmanifest

# ── Proxy all requests to the Node.js process ─────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Don't rewrite if the file physically exists (shouldn't happen for _next/)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Proxy everything to Node.js (Hostinger sets PORT env var)
  RewriteRule ^(.*)$ http://localhost:%{ENV:PORT}/$1 [P,L]
</IfModule>

# ── Cache headers for immutable Next.js static assets ─────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|png|jpg|jpeg|webp|ico|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
