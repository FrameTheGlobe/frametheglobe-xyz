# ── ACLED (Armed Conflict Location & Event Data) ─────────────────────────────
# Free for non-commercial use. Register at: https://developer.acleddata.com/
# Once you have your key, copy this file to .env.local and fill in the values.
#
# Without these the app works fine — ACLED data is simply skipped.

ACLED_API_KEY=your_api_key_here
ACLED_EMAIL=your_registered_email@example.com

# ── Optional ───────────────────────────────────────────────────────────────────
# NODE_ENV=production
