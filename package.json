    "axios": "^1.13.6",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
